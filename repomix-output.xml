.cart-item {
  display: flex;
  width: 667px;
  height: 124px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.1);

  margin-bottom: 24px;
}

.cart-item-img {
  max-width: 125;
  max-height: 124px;
  border-radius: 10px;

  transition: 0.2s ease-in;
}

.cart-item-img:hover {
  transform: scale(0.9);
}

.cart-item-info {
